// Financial Records Entity
model HOAFinancialRecord {
  id            Int      @id @default(autoincrement())
  hoaId         Int      @map("hoa_id")
  recordType    String   @map("record_type") // e.g., "independent_audit", "financial_statement", "budget", "expense_report", "tax_document", etc.
  effectiveDate DateTime @map("effective_date") // For audits: delivery date; for statements: statement date
  description   String?

  // Document URL
  documentUrl String? @map("document_url") // URL to the document (audit report, statement, etc.)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  hoa             HomeOwnerAssociation @relation(fields: [hoaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  relatedInvoices HOAInvoice[] // Invoices that may be associated with this financial record

  // Indexes for performance
  @@index([hoaId])
  @@index([recordType])
  @@index([effectiveDate])
  @@index([hoaId, recordType]) // Composite index for filtering by HOA and document type
  @@index([hoaId, effectiveDate]) // Composite index for HOA financial history queries
  @@map("hoa_financial_records")
  @@schema("api")
}

// HOA Invoice Entity
// Tracks invoices submitted by third-party vendors to HOAs for services provided
model HOAInvoice {
  id                  Int       @id @default(autoincrement())
  hoaId               Int       @map("hoa_id")
  invoiceNumber       String    @map("invoice_number")
  invoiceDate         DateTime  @map("invoice_date")
  invoiceAmount       Decimal   @map("invoice_amount") @db.Decimal(10, 2)
  unpaidInvoiceAmount Decimal?  @map("unpaid_invoice_amount") @db.Decimal(10, 2) // Remaining unpaid amount
  costPaid            Decimal?  @map("cost_paid") @db.Decimal(10, 2) // Amount paid to date
  dueDate             DateTime? @map("due_date")
  paidDate            DateTime? @map("paid_date")

  // Vendor/Provider Information
  vendorName       String? @map("vendor_name")
  vendorBusinessId Int?    @map("vendor_business_id") // Optional link to Business table if vendor is in system

  // Service Details
  serviceType        String? @map("service_type")
  serviceDescription String? @map("service_description")

  // Authorizing Representative Information
  // Exactly one of these must be set (enforced at application level)
  authorizingBoardMemberId       Int? @map("authorizing_board_member_id") // FK to HOABoardMember if authorized by board member
  authorizingManagementCompanyId Int? @map("authorizing_management_company_id") // FK to HOAManagementCompany if authorized by management company

  // Optional link to related financial record (e.g., if invoice is associated with an audit)
  financialRecordId Int? @map("financial_record_id")

  description        String?
  invoiceDocumentUrl String? @map("invoice_document_url") // URL to the invoice document

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  hoa                          HomeOwnerAssociation  @relation(fields: [hoaId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  vendorBusiness               Business?             @relation("HOAInvoiceVendor", fields: [vendorBusinessId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  financialRecord              HOAFinancialRecord?   @relation(fields: [financialRecordId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  authorizingBoardMember       HOABoardMember?       @relation("HOAInvoiceAuthorizingBoardMember", fields: [authorizingBoardMemberId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  authorizingManagementCompany HOAManagementCompany? @relation("HOAInvoiceAuthorizingManagementCompany", fields: [authorizingManagementCompanyId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([hoaId, invoiceNumber]) // Ensure unique invoice numbers per HOA
  // Indexes for performance
  @@index([hoaId])
  @@index([invoiceNumber])
  @@index([invoiceDate])
  @@index([dueDate])
  @@index([paidDate])
  @@index([vendorName])
  @@index([vendorBusinessId])
  @@index([financialRecordId])
  @@index([authorizingBoardMemberId])
  @@index([authorizingManagementCompanyId])
  @@index([hoaId, invoiceDate]) // Composite index for HOA invoice history queries
  @@index([hoaId, dueDate]) // Composite index for finding overdue invoices
  @@index([vendorBusinessId, invoiceDate]) // Composite index for vendor invoice queries
  @@map("hoa_invoices")
  @@schema("api")
}

