model Realtor {
  id             Int      @id @default(autoincrement())
  userId         Int?     @map("user_id") // Optional since User model may not exist
  realtyAgency   String?  @map("realty_agency")
  specialization String?
  locationId     Int?     @map("location_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relationships
  location LocationShard1? @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  // Indexes for performance
  @@index([userId])
  @@index([locationId])
  @@index([realtyAgency])
  @@index([specialization])
  @@map("realtor")
  @@schema("api")
}

// ============================================================================
// SMRC (Service Member Record Collection) SYSTEM
// ============================================================================

// Enumerations for SMRC
enum ResidenceType {
  owned
  rented
  military_housing
  other

  @@map("residence_type")
  @@schema("api")
}

enum TimeAtResidence {
  less_than_6_months
  six_to_12_months
  one_to_two_years
  two_to_five_years
  more_than_five_years

  @@map("time_at_residence")
  @@schema("api")
}

enum LengthOfVisit {
  less_than_one_day
  one_to_three_days
  four_to_seven_days
  one_to_two_weeks
  more_than_two_weeks

  @@map("length_of_visit")
  @@schema("api")
}

enum AgencyLevel {
  federal
  state
  county
  city
  local

  @@map("agency_level")
  @@schema("api")
}

enum DeliveryMethod {
  email
  phone
  in_person
  mail
  online

  @@map("delivery_method")
  @@schema("api")
}

enum RequestStatus {
  pending
  completed
  cancelled
  in_progress

  @@map("request_status")
  @@schema("api")
}

enum ContactMethod {
  phone
  email
  in_person
  mail
  other

  @@map("contact_method")
  @@schema("api")
}

// SMRC Model
model SMRC {
  id     String @id @default(cuid())
  userId String @map("user_id")

  /// Draft / publish state; existing rows without status are treated as 'published'
  status    String? @map("status")
  /// Wizard step for drafts (1–5)
  draftStep Int?    @map("draft_step")
  /// Optional link to video testimonial
  videoUrl  String? @map("video_url")

  // Place of residence
  currentResidence Boolean
  notResident      Boolean
  residenceType    ResidenceType?
  timeAtResidence  TimeAtResidence?
  lengthOfVisit    LengthOfVisit?
  visitDays        Int?
  endDate          DateTime?
  visitBeganAt     DateTime?

  // Location
  state   String
  city    String
  zipCode String @map("zip_code")

  // Agency information
  agencyLevel AgencyLevel @map("agency_level")
  agencyName  String      @map("agency_name")

  // Service details
  serviceReceivedDate DateTime       @map("service_received_date")
  deliveryMethod      DeliveryMethod @map("delivery_method")
  requestStatus       RequestStatus  @map("request_status")
  representativeName  String?        @map("representative_name")

  // Delivery method specific fields
  agencyWebsite         String?   @map("agency_website")
  dateLastEmailReceived DateTime? @map("date_last_email_received")
  representativeEmail   String?   @map("representative_email")
  representativePhone   String?   @map("representative_phone")
  dateLastPhoneContact  DateTime? @map("date_last_phone_contact")

  // In-person location
  locationStreetAddressOne String? @map("location_street_address_one")
  locationStreetAddressTwo String? @map("location_street_address_two")
  locationCity             String? @map("location_city")
  locationState            String? @map("location_state")
  locationZipCode          String? @map("location_zip_code")

  // Recommendation
  shortDescription                 String   @map("short_description")
  recommendation                   Int
  recommendationComments           String[] @map("recommendation_comments")
  recommendationCommentExplanation String?  @map("recommendation_comment_explanation")
  recommendationComment            String?  @map("recommendation_comment")

  // Government contact
  contactedByGovernment          Boolean        @map("contacted_by_government")
  contactedByGovernmentMethod    ContactMethod? @map("contacted_by_government_method")
  contactedByGovernmentPhone     String?        @map("contacted_by_government_phone")
  contactedByGovernmentPhoneTime String?        @map("contacted_by_government_phone_time")
  contactedByGovernmentEmail     String?        @map("contacted_by_government_email")

  // Non-business rating and feedback
  nonBusinessRating             Json?   @map("non_business_rating") @db.JsonB // Object with metric1-15
  nonBusinessExperienceFeedback String? @map("non_business_experience_feedback")

  // Business owner fields
  businessOwner                            Boolean  @map("business_owner")
  businessRecommendation                   Int?     @map("business_recommendation")
  businessRecommendationComments           String[] @map("business_recommendation_comments")
  businessRecommendationCommentExplanation String?  @map("business_recommendation_comment_explanation")
  businessRecommendationComment            String?  @map("business_recommendation_comment")
  businessRating                           Json?    @map("business_rating") @db.JsonB // Object with metric1-10
  businessExperienceFeedback               String?  @map("business_experience_feedback")

  // Other
  hasRecordedVideo Boolean  @default(false) @map("has_recorded_video")
  ipAddress        String?  @map("ip_address")
  isDeleted        Boolean  @default(false) @map("is_deleted")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Indexes for performance
  @@index([userId])
  @@index([state, city])
  @@index([agencyLevel])
  @@index([requestStatus])
  @@index([serviceReceivedDate])
  @@index([isDeleted])
  @@index([createdAt])
  @@map("smrcs")
  @@schema("api")
}

// Simple lookup table for data types used across the platform
model DataType {
  id         String   @id @default(uuid()) @db.Uuid
  identifier String   @map("identifier")
  name       String   @map("name")
  marker     String   @map("marker")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([identifier])
  @@index([name])
  @@index([marker])
  @@map("data_types")
  @@schema("api")
}

// ============================================================================
// ADMIN (PK Admin panel – ties to Supabase Auth)
// ============================================================================

model AdminRole {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @map("name")
  slug      String   @unique @map("slug")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  admins      Admin[]
  permissions AdminRolePermission[]

  @@index([slug])
  @@map("admin_roles")
  @@schema("api")
}

model AdminRolePermission {
  id         String @id @default(uuid()) @db.Uuid
  roleId     String @map("role_id") @db.Uuid
  permission String @map("permission")

  role AdminRole @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permission])
  @@index([roleId])
  @@map("admin_role_permissions")
  @@schema("api")
}

model Admin {
  id          String   @id @db.Uuid // Supabase auth.users.id
  email       String   @unique @map("email")
  displayName String?  @map("display_name")
  roleId      String   @map("role_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  role AdminRole @relation(fields: [roleId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([roleId])
  @@index([email])
  @@map("admins")
  @@schema("api")
}
