// ============================================================================
// EVENT TRACKING SYSTEM
// Comprehensive event tracking for all entity types
// ============================================================================

// e.g., "legal", "administrative", "financial", "operational"
enum EventTypeCategory {
  legal
  administrative
  financial
  operational

  @@map("event_type_category")
  @@schema("api")
}

// e.g., "low", "medium", "high", "critical"
enum EventTypeSeverity {
  low
  medium
  high
  critical

  @@map("event_type_severity")
  @@schema("api")
}

// Event Type Lookup Table
model EventType {
  id          Int                @id @default(autoincrement())
  typeName    String             @map("type_name")
  description String?
  category    EventTypeCategory?
  severity    EventTypeSeverity?
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  // Relationships
  events EventShard1[]

  // Indexes for performance
  @@index([typeName])
  @@index([category])
  @@index([severity])
  @@index([isActive])
  @@map("event_type")
  @@schema("api")
}

// Main Event Table (Sharded)
model EventShard1 {
  id               Int      @id @default(autoincrement())
  eventName        String   @map("event_name")
  eventTypeId      Int      @map("event_type_id")
  eventDate        DateTime @map("event_date")
  eventDocumentUrl String?  @map("event_document_url")
  eventWebpageUrl  String?  @map("event_webpage_url")
  eventAiSummary   String?  @map("event_ai_summary")
  // Additional fields for enhanced functionality
  eventDescription String?  @map("event_description")
  eventStatusId    Int      @map("event_status_id")
  priorityId       Int?     @map("priority_id")
  source           String? // where the event data came from
  verified         Boolean  @default(false) // whether the event has been verified
  stateRegionId    Int      @map("state_region_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  // Relationships
  eventType   EventType     @relation(fields: [eventTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  eventStatus StatusType    @relation(fields: [eventStatusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  priority    PriorityType? @relation(fields: [priorityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stateRegion StateRegion   @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Entity relationships through junction tables
  personEvents     PersonEventShard1[]
  businessEvents   BusinessEventShard1[]
  governmentEvents GovernmentEventShard1[]
  ngoEvents        NGOEventShard1[]

  // Indexes for performance
  @@index([eventTypeId])
  @@index([eventDate])
  @@index([eventStatusId])
  @@index([stateRegionId])
  @@index([priorityId])
  @@index([verified])
  @@index([eventDate, eventStatusId]) // Composite index for common queries
  @@index([stateRegionId, eventStatusId]) // Composite index for regional filtering
  @@index([eventName]) // Event name search
  @@index([source]) // Source tracking
  @@index([eventDate, eventTypeId, eventStatusId])
  @@index([stateRegionId, eventDate, verified])
  @@map("event_shard_1")
  @@schema("api")
}

// e.g., "subject", "witness", "participant", "affected"
enum PersonEventShard1RelationshipType {
  subject
  witness
  participant
  affected

  @@map("person_event_shard_1_relationship_type")
  @@schema("api")
}

