// -----------------------------------------------------------------------------
// HOW TO USE THIS SCHEMA (Monorepo)
//
// Prerequisites:
// - Set DATABASE_URL, DIRECT_DATABASE_URL, and SHADOW_DATABASE_URL.
//   See packages/database/.env.example. Can live in server/.env or
//   packages/database/.env when running Prisma from packages/database.
// - PostgreSQL (e.g. Supabase) reachable from your machine.
//
// From packages/database (PowerShell):
//   cd packages\database
//   npx prisma generate --schema=prisma/schema.prisma
//   npx prisma migrate dev --schema=prisma/schema.prisma --name <name>
//   # or push only (no migration history): npx prisma db push --schema=prisma/schema.prisma
//
// From server (if env is in server/.env):
//   cd server
//   npx prisma generate --schema="../packages/database/prisma/schema.prisma"
//   npx prisma migrate dev --schema="../packages/database/prisma/schema.prisma" --name <name>
// -----------------------------------------------------------------------------
generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["multiSchema", "postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  extensions        = [postgis, uuid_ossp(map: "uuid-ossp", schema: "extensions")]
  schemas           = ["api", "public"]
  shadowDatabaseUrl = env("SHADOW_DATABASE_URL")
}

// Enumerations
enum GeographicReferenceType {
  state
  county
  city
  zip

  @@map("geographic_reference_type")
  @@schema("api")
}

// ============================================================================
// GOVERNMENT DATA ANALYTICS PLATFORM SCHEMA
// Based on SOFTWARE_REQS_SPEC.html ER Diagram
// ============================================================================

// Geographic Hierarchy Entities
model State {
  id           Int      @id @default(autoincrement()) @map("state_id")
  stateName    String   @map("state_name")
  abbreviation String
  population   Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  counties           County[]
  governmentEntities GovernmentEntity[]
  businesses         Business[]
  ngos               NonGovernmentalOrganizationShard1[]
  stateReviews       StateReviewShard1[]
  classifications    Classification[]
  crimeStatutes      CrimeStatute[]
  statutes           Statute[]

  @@map("state")
  @@schema("api")
}

model County {
  id         Int      @id @default(autoincrement()) @map("county_id")
  countyName String   @map("county_name")
  population Int?
  stateId    Int      @map("state_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relationships
  state              State                               @relation(fields: [stateId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  cities             City[]
  governmentEntities GovernmentEntity[]
  businesses         Business[]
  ngos               NonGovernmentalOrganizationShard1[]
  countyReviews      CountyReviewShard1[]

  // Indexes for performance
  @@index([stateId])
  @@index([countyName])
  @@map("county")
  @@schema("api")
}

model City {
  id         Int      @id @default(autoincrement()) @map("city_id")
  cityName   String   @map("city_name")
  population Int?
  countyId   Int      @map("county_id")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relationships
  county             County                              @relation(fields: [countyId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  zipCodes           ZipCode[]
  governmentEntities GovernmentEntity[]
  businesses         Business[]
  ngos               NonGovernmentalOrganizationShard1[]
  cityReviews        CityReviewShard1[]
  populationHistory  PopulationHistory[]
  schoolDistricts    SchoolDistrict[]
  schools            School[]

  // Indexes for performance
  @@index([countyId])
  @@index([cityName])
  @@map("city")
  @@schema("api")
}

model ZipCode {
  id        Int      @id @default(autoincrement()) @map("zip_code_id")
  zipCode   String   @map("zip_code")
  cityId    Int      @map("city_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relationships
  city      City             @relation(fields: [cityId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  locations LocationShard1[]

  // Indexes for performance
  @@index([cityId])
  @@index([zipCode])
  @@map("zip_code")
  @@schema("api")
}

// Location and Type Entities
model LocationShard1 {
  id             Int                                  @id @default(autoincrement())
  streetAddress1 String                               @map("street_address_1")
  streetAddress2 String?                              @map("street_address_2")
  locationTypeId Int                                  @map("location_type_id")
  zipCodeId      Int                                  @map("zip_code_id")
  stateRegionId  Int                                  @map("state_region_id")
  // PostGIS geometry for advanced geospatial queries
  coordinates    Unsupported("geometry(Point,4326)")? // PostGIS Point geometry
  // Additional geospatial fields for search
  latitude       Float? // Decimal degrees (computed from coordinates)
  longitude      Float? // Decimal degrees (computed from coordinates)
  createdAt      DateTime                             @default(now()) @map("created_at")
  updatedAt      DateTime                             @updatedAt @map("updated_at")

  // Relationships
  locationType          LocationType                        @relation(fields: [locationTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  zipCode               ZipCode                             @relation(fields: [zipCodeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stateRegion           StateRegion                         @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  governmentEntities    GovernmentEntity[]
  businesses            Business[]
  ngos                  NonGovernmentalOrganizationShard1[]
  homeOwnerAssociations HomeOwnerAssociation[]
  homeBuilders          HomeBuilder[]
  realtors              Realtor[]

  // Indexes for geospatial performance
  @@index([latitude, longitude])
  @@index([zipCodeId])
  @@index([stateRegionId])
  @@index([locationTypeId])
  @@index([streetAddress1])
  @@index([stateRegionId, latitude, longitude]) // Composite for regional geo queries
  @@map("location_shard_1")
  @@schema("api")
}

model LocationType {
  id           Int      @id @default(autoincrement())
  locationType String   @map("location_type")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relationships
  locations LocationShard1[]

  @@map("location_type")
  @@schema("api")
}

// Core Entities
model Person {
  id          Int       @id @default(autoincrement())
  prefix      String?
  firstName   String    @map("first_name")
  middleName  String?   @map("middle_name")
  lastName    String    @map("last_name")
  suffix      String?
  dateOfBirth DateTime? @map("date_of_birth")
  gender      String?
  juvenile    Boolean   @default(false)
  deceased    Boolean   @default(false)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // RBCA user fields - Firebase auth and profile (populated for RBCA registrations)
  firebaseUserId             String?  @unique @map("firebase_user_id")
  email                      String?  @map("email")
  username                   String?  @map("username")
  stateOfResidence           String?  @map("state_of_residence")
  cityOfResidence            String?  @map("city_of_residence")
  zipCode                    String?  @map("zip_code")
  namePrefixId               Int?     @map("name_prefix_id")
  nameSuffixId               Int?     @map("name_suffix_id")
  privacyLevelId             Int?     @map("privacy_level_id")
  referralSourceId           Int?     @map("referral_source_id")
  referralText               String?  @map("referral_text")
  hashedPassword             String?  @map("hashed_password")
  signInMethod               String?  @map("sign_in_method")
  emailVerified              Boolean? @map("email_verified")
  onboardingComplete         Boolean? @map("onboarding_complete")
  motivationIds              Json?    @map("motivation_ids")
  otherInterestText          String?  @map("other_interest_text")
  governmentIds              Json?    @map("government_ids")
  informationSourceIds       Json?    @map("information_source_ids")
  otherInformationSourceText String?  @map("other_information_source_text")
  agreementAccepted          Boolean? @map("agreement_accepted")
  registrationData           Json?    @map("registration_data")
  lastUpdatedFirebase        String?  @map("last_updated_firebase")

  // Relationships
  businessesAsChief Business[]                          @relation("BusinessChiefExecutive")
  ngosAsPrincipal   NonGovernmentalOrganizationShard1[] @relation("NGOPrincipalOfficer")
  personEvents      PersonEventShard1[]

  // Indexes for performance
  @@index([firstName, lastName])
  @@index([dateOfBirth])
  @@index([juvenile])
  @@index([lastName, firstName, juvenile])
  @@index([dateOfBirth, juvenile])
  @@index([firebaseUserId])
  @@index([email])
  @@index([username])
  // Data validation constraints")
  @@map("person")
  @@schema("api")
}

model GovernmentEntity {
  id                Int      @id @default(autoincrement())
  entityName        String   @map("entity_name")
  governmentLevelId Int      @map("government_level_id")
  stateId           Int?     @map("state_id")
  countyId          Int?     @map("county_id")
  cityId            Int?     @map("city_id")
  locationId        Int?     @map("location_id")
  // Enhanced fields for search functionality
  entityType        String?  @map("entity_type") // e.g., "department", "agency", "office"
  description       String? // Brief description of the entity
  website           String? // Official website URL
  phone             String? // Contact phone number
  email             String? // Contact email
  // Geospatial coordinates for map integration
  latitude          Float? // Decimal degrees
  longitude         Float? // Decimal degrees
  // Search and filtering fields
  hasReviews        Boolean  @default(false) @map("has_reviews")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  // Relationships
  governmentLevel        GovernmentLevel               @relation(fields: [governmentLevelId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  state                  State?                        @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  county                 County?                       @relation(fields: [countyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  city                   City?                         @relation(fields: [cityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  location               LocationShard1?               @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stateReviews           StateReviewShard1[]
  countyReviews          CountyReviewShard1[]
  cityReviews            CityReviewShard1[]
  governmentEvents       GovernmentEventShard1[]
  personOrgRelationships PersonOrgRelationshipShard1[]
  // Fiscal Analysis Relationships
  acfrReports            ACFRReport[]
  pensionPlans           PensionPlan[]
  opebData               OPEBDataShard1[]
  fiscalHealthScores     FiscalHealthScore[]

  // Indexes for search performance
  @@index([governmentLevelId])
  @@index([stateId])
  @@index([countyId])
  @@index([cityId])
  @@index([entityType])
  @@index([hasReviews])
  @@index([isActive])
  @@index([entityName]) // Full-text search index
  @@index([latitude, longitude]) // Geospatial index
  @@index([stateId, entityType]) // Composite index for state-level filtering
  @@index([isActive, hasReviews]) // Composite index for active entities with reviews
  @@index([isActive, hasReviews, stateId])
  @@index([entityType, isActive, governmentLevelId])
  // Data validation constraints")")
  @@map("government_entity")
  @@schema("api")
}

// Business Entities
model Business {
  id                            Int       @id @default(autoincrement())
  name                          String
  chiefExecutiveId              Int?      @map("chief_executive")
  businessLicenseNumber         String?   @map("business_license_number")
  businessLicenseStatusId       Int?      @map("business_license_status")
  businessLicenseExpirationDate DateTime? @map("business_license_expiration_date")
  businessTypeId                Int?      @map("business_type")
  serviceCategoryId             Int?      @map("service_category")
  employeeCountRangeId          Int?      @map("employee_count_range")
  annualRevenueRangeId          Int?      @map("annual_revenue_range")
  minorityOwnedBusiness         Boolean   @default(false) @map("minority_owned_business")
  womenOwnedBusiness            Boolean   @default(false) @map("women_owned_business")
  veteranOwnedBusiness          Boolean   @default(false) @map("veteran_owned_business")
  website                       String?
  locationId                    Int?      @map("location_id")
  stateId                       Int?      @map("state_id")
  countyId                      Int?      @map("county_id")
  cityId                        Int?      @map("city_id")
  stateRegionId                 Int       @map("state_region_id")
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  // Relationships
  chiefExecutive         Person?                @relation("BusinessChiefExecutive", fields: [chiefExecutiveId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  location               LocationShard1?        @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  state                  State?                 @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  county                 County?                @relation(fields: [countyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  city                   City?                  @relation(fields: [cityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stateRegion            StateRegion            @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  businessEvents         BusinessEventShard1[]
  hoaInvoicesAsVendor    HOAInvoice[]           @relation("HOAInvoiceVendor")
  hoaManagementCompanies HOAManagementCompany[]

  // Indexes for performance
  @@index([stateRegionId])
  @@index([businessTypeId])
  @@index([serviceCategoryId])
  @@index([minorityOwnedBusiness])
  @@index([womenOwnedBusiness])
  @@index([veteranOwnedBusiness])
  @@index([stateRegionId, businessTypeId]) // Composite index for regional business filtering
  @@index([minorityOwnedBusiness, womenOwnedBusiness]) // Composite index for diversity queries
  @@index([name]) // Business name search
  @@index([businessLicenseNumber]) // License lookup
  @@index([chiefExecutiveId]) // CEO lookup
  @@index([businessLicenseStatusId, businessLicenseExpirationDate])
  // Data validation constraints?$'")
  @@map("business")
  @@schema("api")
}

// NGO Entities
model NonGovernmentalOrganizationShard1 {
  employerIdentificationNumber String   @id @map("employer_identification_number")
  name                         String
  principalOfficerId           Int?     @map("principal_officer")
  ngoType                      String?  @map("ngo_type")
  guidestarProfilePageUrl      String?  @map("guidestar_profile_page_url")
  locationId                   Int?     @map("location_id")
  ngoWebsiteUrl                String?  @map("ngo_website_url")
  stateId                      Int?     @map("state_id")
  countyId                     Int?     @map("county_id")
  cityId                       Int?     @map("city_id")
  stateRegionId                Int      @map("state_region_id")
  createdAt                    DateTime @default(now()) @map("created_at")
  updatedAt                    DateTime @updatedAt @map("updated_at")

  // Relationships
  principalOfficer Person?          @relation("NGOPrincipalOfficer", fields: [principalOfficerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  location         LocationShard1?  @relation(fields: [locationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  state            State?           @relation(fields: [stateId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  county           County?          @relation(fields: [countyId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  city             City?            @relation(fields: [cityId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  stateRegion      StateRegion      @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  ngoEvents        NGOEventShard1[]

  // Indexes for performance
  @@index([stateRegionId])
  @@index([ngoType])
  @@index([name])
  @@index([principalOfficerId])
  // Data validation constraints?$'")?$'")
  @@map("non_governmental_organization_shard_1")
  @@schema("api")
}

// Review/Complaint System Entities
model StateReviewShard1 {
  id                 Int      @id @default(autoincrement())
  governmentEntityId Int      @map("government_entity_id")
  stateId            Int      @map("state_id")
  reviewTypeId       Int      @map("review_type_id")
  reviewText         String   @map("review_text")
  rating             Int?
  reviewerName       String?  @map("reviewer_name")
  reviewerEmail      String?  @map("reviewer_email")
  isVerified         Boolean  @default(false) @map("is_verified")
  statusId           Int      @map("status_id")
  stateRegionId      Int      @map("state_region_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relationships
  governmentEntity GovernmentEntity @relation(fields: [governmentEntityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  state            State            @relation(fields: [stateId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewType       ReviewType       @relation(fields: [reviewTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status           StatusType       @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stateRegion      StateRegion      @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Indexes for performance
  @@index([governmentEntityId])
  @@index([stateId])
  @@index([reviewTypeId])
  @@index([statusId])
  @@index([stateRegionId])
  @@index([rating])
  @@index([isVerified])
  @@index([createdAt])
  // Data validation constraints")
  @@map("state_review_shard_1")
  @@schema("api")
}

model CountyReviewShard1 {
  id                 Int      @id @default(autoincrement())
  governmentEntityId Int      @map("government_entity_id")
  countyId           Int      @map("county_id")
  reviewTypeId       Int      @map("review_type_id")
  reviewText         String   @map("review_text")
  rating             Int?
  reviewerName       String?  @map("reviewer_name")
  reviewerEmail      String?  @map("reviewer_email")
  isVerified         Boolean  @default(false) @map("is_verified")
  statusId           Int      @map("status_id")
  stateRegionId      Int      @map("state_region_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relationships
  governmentEntity GovernmentEntity @relation(fields: [governmentEntityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  county           County           @relation(fields: [countyId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewType       ReviewType       @relation(fields: [reviewTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status           StatusType       @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stateRegion      StateRegion      @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Indexes for performance
  @@index([governmentEntityId])
  @@index([countyId])
  @@index([reviewTypeId])
  @@index([statusId])
  @@index([stateRegionId])
  @@index([rating])
  @@index([isVerified])
  @@index([createdAt])
  // Data validation constraints")
  @@map("county_review_shard_1")
  @@schema("api")
}

model CityReviewShard1 {
  id                 Int      @id @default(autoincrement())
  governmentEntityId Int      @map("government_entity_id")
  cityId             Int      @map("city_id")
  reviewTypeId       Int      @map("review_type_id")
  reviewText         String   @map("review_text")
  rating             Int?
  reviewerName       String?  @map("reviewer_name")
  reviewerEmail      String?  @map("reviewer_email")
  isVerified         Boolean  @default(false) @map("is_verified")
  statusId           Int      @map("status_id")
  stateRegionId      Int      @map("state_region_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relationships
  governmentEntity GovernmentEntity @relation(fields: [governmentEntityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  city             City             @relation(fields: [cityId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  reviewType       ReviewType       @relation(fields: [reviewTypeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status           StatusType       @relation(fields: [statusId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  stateRegion      StateRegion      @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Indexes for performance
  @@index([governmentEntityId])
  @@index([cityId])
  @@index([reviewTypeId])
  @@index([statusId])
  @@index([stateRegionId])
  @@index([rating])
  @@index([isVerified])
  @@index([createdAt])
  // Data validation constraints")
  @@map("city_review_shard_1")
  @@schema("api")
}

// Sharding Infrastructure Tables
model TableRegistry {
  id                  Int      @id @default(autoincrement())
  tableName           String   @map("table_name")
  shardKeyColumn      String   @map("shard_key_column")
  maxRecordsPerShard  Int?     @map("max_records_per_shard")
  currentActiveShards Int      @default(1) @map("current_active_shards")
  autoScalingEnabled  Boolean  @default(false) @map("auto_scaling_enabled")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  // Relationships
  shardRegistries TableShardRegistry[]

  @@map("table_registry")
  @@schema("api")
}

model TableShardRegistry {
  id                 Int       @id @default(autoincrement())
  tableRegistryId    Int       @map("table_registry_id")
  shardNumber        Int       @map("shard_number")
  stateRegionId      Int       @map("state_region_id")
  currentRecordCount Int       @default(0) @map("current_record_count")
  status             String    @default("active")
  databaseServer     String?   @map("database_server")
  lastMaintenance    DateTime? @map("last_maintenance")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  // Relationships
  tableRegistry TableRegistry @relation(fields: [tableRegistryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  stateRegion   StateRegion   @relation(fields: [stateRegionId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  // Indexes for performance
  @@index([tableRegistryId])
  @@index([stateRegionId])
  @@index([shardNumber])
  @@index([status])
  @@map("table_shard_registry")
  @@schema("api")
}

model StateRegion {
  id          Int      @id @default(autoincrement())
  regionName  String   @map("region_name")
  regionCode  String   @map("region_code")
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relationships
  locations              LocationShard1[]
  businesses             Business[]
  ngos                   NonGovernmentalOrganizationShard1[]
  stateReviews           StateReviewShard1[]
  countyReviews          CountyReviewShard1[]
  cityReviews            CityReviewShard1[]
  shardRegistries        TableShardRegistry[]
  crimeReports           CrimeReportIncidentShard1[]
  educationData          EducationDataShard1[]
  classes                ClassShard1[]
  classEnrollments       ClassEnrollmentShard1[]
  pensionPlans           PensionPlan[]
  teacherCredentials     TeacherCredentialShard1[]
  gradeProgressions      GradeProgressionShard1[]
  disciplinaryActions    DisciplinaryActionShard1[]
  employmentData         EmploymentDataShard1[]
  businessLicenses       BusinessLicenseShard1[]
  housingStatus          HousingStatusShard1[]
  personLocations        PersonLocationShard1[]
  organizationLocations  OrganizationLocationShard1[]
  personOrgRelationships PersonOrgRelationshipShard1[]
  // Event tracking relationships
  events                 EventShard1[]
  personEvents           PersonEventShard1[]
  businessEvents         BusinessEventShard1[]
  governmentEvents       GovernmentEventShard1[]
  ngoEvents              NGOEventShard1[]
  // Audit logging
  auditLogs              AuditLog[]
  // Fiscal Analysis Relationships
  acfrReports            ACFRReport[]
  fiscalData             FiscalDataShard1[]
  pensionData            PensionDataShard1[]
  opebData               OPEBDataShard1[]
  fiscalHealthScores     FiscalHealthScore[]
  schools                School[]

  // Indexes for performance
  @@index([regionName])
  @@index([regionCode])
  @@index([isActive])
  @@map("state_region")
  @@schema("api")
}

// Lookup Tables
model GovernmentLevel {
  id             Int      @id @default(autoincrement())
  levelName      String   @map("level_name")
  hierarchyOrder Int      @map("hierarchy_order")
  description    String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Relationships
  governmentEntities GovernmentEntity[]

  // Indexes for performance
  @@index([levelName])
  @@index([hierarchyOrder])
  @@map("government_level")
  @@schema("api")
}

model OrganizationType {
